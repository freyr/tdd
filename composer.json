{
    "name": "freyr/tdd",
    "description": "Basic PHP 8.3 project with PHPUnit for testing.",
    "type": "project",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^12.3",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Freyr\\TDD\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Freyr\\TDD\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "license": "MIT"
}
